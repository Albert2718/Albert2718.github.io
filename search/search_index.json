{"config":{"lang":["zh","en","ja"],"separator":"[\\s\\u200b\\-]","pipeline":["stemmer"]},"docs":[{"location":"","title":"\u6b22\u8fce\u200b\uff01","text":"<p>\u200b\u6b22\u8fce\u200b\u6765\u5230\u200b\u6211\u200b\u7684\u200b\u6708\u5149\u5b9d\u76d2\u200b~   </p> <p>\u200b\u5b9d\u76d2\u200b\u4e4b\u4e0a\u200b\u523b\u7740\u200b\u4e00\u53e5\u200b\u68b5\u6587\u200b\uff1a\u200b\u822c\u82e5\u200b\u6ce2\u7f57\u871c\u200b(praj\u00f1\u0101-p\u0101ramit\u0101)\uff1a</p> <p>\u201c\u200b\u822c\u82e5\u200b\u201d\u200b\u4ee3\u8868\u200b\u6df1\u523b\u200b\u7684\u200b\u667a\u6167\u200b\uff0c\u201c\u200b\u6ce2\u7f57\u871c\u200b\u201d\u200b\u610f\u5473\u7740\u200b\u5230\u8fbe\u200b\u5f7c\u5cb8\u200b\u3002  </p> <p>\u200b\u613f\u200b\u4f60\u200b\u6211\u200b\u7ec8\u5c06\u200b\u62b5\u8fbe\u200b\u5f7c\u5cb8\u200b~  </p>"},{"location":"about/","title":"\u5173\u4e8e\u200b\u6211","text":"<p>\u200b\u4f60\u597d\u200b\uff01\u200b\u6211\u200b\u662f\u200b\u6d59\u6c5f\u5927\u5b66\u200b23\u200b\u5c4a\u200b\u5b66\u751f\u200b\uff0c\u200b\u4e3b\u4fee\u200b\u81ea\u52a8\u5316\u200b\u63a7\u5236\u200b\u3002</p>"},{"location":"about/#moonbox","title":"\u5173\u4e8e\u200bMoonBox\uff08\u200b\u5f85\u200b\u66f4\u65b0\u200b\uff09","text":""},{"location":"about/#_1","title":"\u5173\u4e8e\u200b\u8bfe\u7a0b\u200b\u7b14\u8bb0","text":"<p>\u200b\u6211\u200b\u4e0d\u200b\u5e0c\u671b\u200b\u628a\u200b\u7b14\u8bb0\u200b\u53d8\u6210\u200b\u8bfe\u4ef6\u200b\u7684\u200b\u590d\u5236\u7c98\u8d34\u200b\uff0c\u200b\u66f4\u200b\u5e0c\u671b\u200b\u5728\u200b\u96be\u4ee5\u200b\u7406\u89e3\u200b\u7684\u200b\u90e8\u5206\u200b\u901a\u8fc7\u200b\u5199\u200b\u7b14\u8bb0\u200b\u52a0\u6df1\u200b\u81ea\u5df1\u200b\u7684\u200b\u7406\u89e3\u200b\uff0c\u200b\u6240\u4ee5\u200b\u8bfe\u7a0b\u200b\u5bb9\u6613\u200b\u7406\u89e3\u200b\u7684\u200b\u5730\u65b9\u200b\uff0c\u200b\u6211\u200b\u53ef\u80fd\u200b\u4e0d\u4f1a\u200b\u4e3a\u4e86\u200b\u8ffd\u6c42\u200b\u5185\u5bb9\u200b\u7684\u200b\u5b8c\u6574\u6027\u200b\u800c\u200b\u8bb0\u5f55\u200b\u7684\u200b\u5341\u5206\u200b\u5468\u5168\u200b\u3002\u200b\u4f1a\u200b\u66f4\u200b\u591a\u200b\u7684\u200b\u5728\u200b\u96be\u70b9\u200b\u3001\u200b\u91cd\u70b9\u200b\u4e0a\u200b\u52a0\u5165\u200b\u81ea\u5df1\u200b\u7684\u200b\u601d\u8003\u200b\u6216\u8005\u200b\u9644\u4e0a\u200b\u5bf9\u6b64\u200b\u6709\u200b\u542f\u53d1\u200b\u7684\u200b\u8d44\u6599\u200b\u3002  </p> <p>\u200b\u4e0e\u6b64\u540c\u65f6\u200b\uff0c\u200b\u5982\u679c\u200b\u5176\u4ed6\u4eba\u200b\u770b\u5230\u200b\u6211\u200b\u7684\u200b\u7b14\u8bb0\u200b\u65f6\u200b\uff0c\u200b\u80fd\u591f\u200b\u6709\u200b\u4e00\u70b9\u70b9\u200b\u6536\u83b7\u200b\uff0c\u200b\u90a3\u200b\u5c31\u200b\u518d\u597d\u4e0d\u8fc7\u200b\u4e86\u200b~</p>"},{"location":"recent/","title":"\u8ba1\u5212\u200b\u66f4\u65b0","text":""},{"location":"recent/#_2","title":"\u8fd1\u671f","text":"<ul> <li>\u200b\u5927\u7269\u200b\u5b9e\u9a8c\u200bchapter0\u200b\u7b14\u8bb0\u200b</li> <li>\u200b\u7f8e\u5316\u200b\u9996\u9875\u200band\u200b\u7ed9\u200b\u7f51\u7ad9\u200b\u589e\u52a0\u200b\u56fe\u6807\u200b</li> <li>\u200b\u590d\u53d8\u200b\u51fd\u6570\u200b\u540e\u534a\u6bb5\u200b\u96be\u70b9\u200b</li> </ul>"},{"location":"recent/#_3","title":"\u4e0d\u5b9a\u671f","text":"<ul> <li>\u200b\u5efa\u7acb\u200b\u79d1\u5b66\u5e7b\u60f3\u200b\u7684\u200bsection</li> <li>\u200b\u7b49\u200b\u67d0\u4f4d\u200b\u670b\u53cb\u200b\u5efa\u5b8c\u200b\u81ea\u5df1\u200b\u7684\u200bweb\u200b\u540e\u200b\u7ed9\u200b\u4ed6\u200b\u52a0\u4e2a\u200b\u53cb\u94fe\u200b~</li> </ul>"},{"location":"notes/astronomy/chapter_0/","title":"\u7eea\u8bba","text":"<p>\u200b\u661f\u7a7a\u200b\u8d4b\u4e88\u200b\u4e86\u200b\u4eba\u7c7b\u200b\u6700\u5927\u200b\u7684\u200b\u9050\u60f3\u200b </p>"},{"location":"notes/phylab/chapter_0/","title":"\u7eea\u8bba","text":""},{"location":"notes/phylab/chapter_0/#_1","title":"\u5b9e\u9a8c\u200b\u6d4b\u91cf","text":""},{"location":"notes/phylab/chapter_0/#_2","title":"\u5173\u4e8e\u200b\u6d4b\u91cf","text":"<ul> <li>\u200b\u76f4\u63a5\u200b\u6d4b\u91cf\u200b\uff1a\u200b\u6240\u200b\u8981\u200b\u6d4b\u91cf\u200b\u7684\u200b\u91cf\u200b\u4e0d\u5fc5\u200b\u5c06\u200b\u5b9e\u6d4b\u200b\u7684\u200b\u91cf\u200b\u7ecf\u8fc7\u200b\u4efb\u4f55\u200b\u51fd\u6570\u200b\u5173\u7cfb\u200b\u7684\u200b\u8ba1\u7b97\u200b\u800c\u200b\u76f4\u63a5\u200b\u5f97\u5230\u200b\u3002</li> <li>\u200b\u95f4\u63a5\u6d4b\u91cf\u200b\uff1a\u200b\u901a\u8fc7\u200b\u6b32\u200b\u6d4b\u91cf\u200b\u7684\u200b\u91cf\u200b\u4e0e\u200b\u76f4\u63a5\u200b\u5b9e\u6d4b\u200b\u7684\u200b\u91cf\u200b\u4e4b\u95f4\u200b\u7684\u200b\u5df2\u77e5\u200b\u51fd\u6570\u200b\u5173\u7cfb\u200b\uff0c\u200b\u7ecf\u8fc7\u200b\u8ba1\u7b97\u200b\u95f4\u63a5\u200b\u5f97\u5230\u200b\u6b32\u200b\u6d4b\u91cf\u200b\u7684\u200b\u91cf\u200b\u3002</li> </ul>"},{"location":"notes/phylab/chapter_0/#_3","title":"\u6709\u6548\u4f4d\u6570","text":"<ul> <li>\u200b\u53ef\u9760\u200b\u6570\u5b57\u200b\uff1a\u200b\u901a\u8fc7\u200b\u76f4\u8bfb\u200b\u83b7\u5f97\u200b\u7684\u200b\u51c6\u786e\u200b\u6570\u5b57\u200b\u3002</li> <li>\u200b\u5b58\u7591\u200b\u6570\u5b57\u200b\uff1a\u200b\u901a\u8fc7\u200b\u4f30\u8bfb\u200b\u5f97\u5230\u200b\u7684\u200b\u6570\u5b57\u200b\u3002</li> <li>\u200b\u6709\u6548\u6570\u5b57\u200b\u548c\u200b\u6709\u6548\u4f4d\u6570\u200b\uff1a\u200b\u6d4b\u91cf\u200b\u503c\u200b\u7684\u200b\u53ef\u9760\u200b\u6570\u200b\u52a0\u4e0a\u200b\u4e00\u4f4d\u200b\u5b58\u7591\u200b\u6570\u200b\u7684\u200b\u5168\u90e8\u200b\u6570\u5b57\u200b\u79f0\u4e3a\u200b\u6709\u6548\u6570\u5b57\u200b\u3002\u200b\u5176\u200b\u603b\u200b\u4f4d\u6570\u200b\u79f0\u4e3a\u200b\u8be5\u200b\u6d4b\u91cf\u200b\u7684\u200b\u6709\u6548\u4f4d\u6570\u200b\u3002</li> </ul> <p>\u200b\u4f8b\u5b50\u200b</p> <p></p>"},{"location":"notes/phylab/chapter_0/#_4","title":"\u5404\u79cd\u200b\u4eea\u5668\u200b\u7684\u200b\u4f7f\u7528\u200b\u65b9\u6cd5\u200b\uff08\u200b\u5f85\u200b\u66f4\u65b0\u200b\uff09","text":""},{"location":"notes/phylab/chapter_0/#_5","title":"\u5b9e\u9a8c\u200b\u8bef\u5dee","text":""},{"location":"notes/phylab/chapter_0/#_6","title":"\u8bef\u5dee\u200b\u8868\u793a","text":"<ol> <li>\u200b\u7edd\u5bf9\u8bef\u5dee\u200b=\u200b\u6d4b\u91cf\u200b\u7ed3\u679c\u200b-\u200b\u88ab\u200b\u6d4b\u91cf\u200b\u7684\u200b\u771f\u503c\u200b</li> <li>\u200b\u76f8\u5bf9\u8bef\u5dee\u200b\uff08\u200b\u767e\u5206\u200b\u8bef\u5dee\u200b\uff09\uff1a $$ E = \\frac{\\left| \\text{\u200b\u6d4b\u91cf\u200b\u503c\u200b} - \\text{\u200b\u771f\u503c\u200b} \\right|}{\\text{\u200b\u771f\u503c\u200b}} \\times 100\\% $$</li> <li>\u200b\u6807\u51c6\u8bef\u5dee\u200b\uff08\u200b\u6807\u51c6\u5dee\u200b\uff09\uff1a $$ S = \\sqrt{\\frac{1}{n-1} \\sum_{i=1}^{n} |\\text{\u200b\u7edd\u5bf9\u8bef\u5dee\u200b}|^2} $$ \u200b\u4e3a\u4ec0\u4e48\u200b\u5206\u6bcd\u200b\u662f\u200b \\(n-1\\) \u200b\u4e0d\u662f\u200b \\(n\\) ?</li> </ol>"},{"location":"notes/phylab/chapter_0/#_7","title":"\u8bef\u5dee\u200b\u5206\u7c7b","text":"<p>\u200b\u4f8b\u5b50\u200b</p> <p></p>"},{"location":"notes/phylab/chapter_0/#_8","title":"\u968f\u673a\u53d8\u91cf\u200b\u7684\u200b\u7edf\u8ba1\u200b\u89c4\u5f8b\u200b\uff08\u200b\u5f85\u200b\u66f4\u65b0\u200b\uff09","text":"<p>\u200b\u8fd9\u200b\u6bb5\u200b\u53ef\u80fd\u200b\u5b66\u4e86\u200b\u6982\u7edf\u200b\u518d\u200b\u66f4\u65b0\u200b~</p>"},{"location":"notes/phylab/chapter_0/#_9","title":"\u5b9e\u9a8c\u200b\u6570\u636e\u5904\u7406","text":""},{"location":"notes/phylab/chapter_0/#_10","title":"\u4e0d\u200b\u786e\u5b9a\u200b\u5ea6","text":"<ul> <li>\u200b\u4e0d\u200b\u786e\u5b9a\u200b\u5ea6\u200b\u8868\u793a\u200b\u7531\u4e8e\u200b\u6d4b\u91cf\u8bef\u5dee\u200b\u5b58\u5728\u200b\u800c\u200b\u5bf9\u200b\u88ab\u200b\u6d4b\u91cf\u200b\u503c\u200b\u4e0d\u80fd\u200b\u786e\u5b9a\u200b\u7684\u200b\u7a0b\u5ea6\u200b\u3002\u200b\u4e0d\u200b\u786e\u5b9a\u200b\u5ea6\u200b\u662f\u200b\u4e00\u5b9a\u200b\u6982\u7387\u200b\u4e0b\u200b\u7684\u200b\u8bef\u5dee\u200b\u9650\u503c\u200b\u3002</li> <li>\u200b\u4e0d\u200b\u786e\u5b9a\u200b\u5ea6\u200b\u53cd\u6620\u200b\u4e86\u200b\u53ef\u80fd\u200b\u5b58\u5728\u200b\u7684\u200b\u8bef\u5dee\u200b\u5206\u5e03\u200b\u8303\u56f4\u200b\uff0c\u200b\u5373\u200b\u968f\u673a\u8bef\u5dee\u200b\u5206\u91cf\u200b\u548c\u200b\u672a\u5b9a\u200b\u7cfb\u7edf\u8bef\u5dee\u200b\u7684\u200b\u8054\u5408\u200b\u5206\u5e03\u200b\u8303\u56f4\u200b\u3002</li> <li>\u200b\u7531\u4e8e\u200b\u771f\u503c\u200b\u7684\u200b\u4e0d\u200b\u53ef\u77e5\u200b\uff0c\u200b\u8bef\u5dee\u200b\u4e00\u822c\u200b\u662f\u200b\u4e0d\u80fd\u200b\u8ba1\u7b97\u200b\u7684\u200b\uff0c\u200b\u5b83\u200b\u53ef\u6b63\u200b\u3001\u200b\u53ef\u8d1f\u200b\u4e5f\u200b\u53ef\u80fd\u200b\u5341\u5206\u200b\u63a5\u8fd1\u200b\u96f6\u200b\uff1b\u200b\u800c\u200b\u4e0d\u200b\u786e\u5b9a\u200b\u5ea6\u200b\u603b\u662f\u200b\u4e0d\u4e3a\u200b\u96f6\u200b\u7684\u200b\u6b63\u503c\u200b\uff0c\u200b\u662f\u200b\u53ef\u4ee5\u200b\u5177\u4f53\u200b\u8bc4\u5b9a\u200b\u7684\u200b\u3002</li> </ul>"},{"location":"notes/phylab/chapter_0/#_11","title":"\u6709\u6548\u6570\u5b57","text":"<p>\u200b\u6709\u6548\u6570\u5b57\u200b\u4fee\u7ea6\u200b\u539f\u5219\u200b\uff1a \u200b\u56db\u820d\u200b\u516d\u200b\u2f0a\u200b\u4e94\u51d1\u200b\u53cc\u200b</p> <p>\u200b\u4f8b\u5b50\u200b</p> <p></p>"},{"location":"notes/phylab/chapter_0/#_12","title":"\u6570\u636e\u5904\u7406\u200b\u65b9\u6cd5","text":"<ol> <li>\u200b\u5217\u8868\u200b\u6cd5\u200b</li> <li>\u200b\u9010\u5dee\u6cd5\u200b</li> <li>\u200b\u4f5c\u56fe\u200b\u6cd5\u200b \u200b\u5c3d\u53ef\u80fd\u200b\u5229\u7528\u200b\u76f4\u7ebf\u200b</li> <li>\u200b\u6700\u5c0f\u200b\u4e8c\u200b\u4e58\u6cd5\u200b</li> </ol>"}]}